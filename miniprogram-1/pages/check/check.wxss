/* pages/check/check.wxss */
.container {
  padding: 20px;
  display: flex;
  gap:1px;
}

.table {
  width: 100%;
}

.table-row {
  display: flex;
}

.table-cell {
  flex: 1;
  padding: 10px;
  text-align: center;
  border: 1px solid #ddd;
  
}

.table-row:last-child {
  border-bottom: none;
}
.custom-tab-bar {
  display: flex;
  justify-content: space-around;
  align-items: center;
  background-color: #ffffff;
  border-top: 1px solid #eaeaea;
  padding: 10px 0;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.tab-item text {
  font-size: 12px;
  color: #7A7E83;
}

.tab-item van-icon {
  font-size: 24px;
  color: #7A7E83;
}

/* 激活状态的样式 */
.tab-item[data-active="true"] text {
  color: #3cc51f;
}

.tab-item[data-active="true"] van-icon {
  color: #3cc51f;
}